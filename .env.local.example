# ==============================
# EU Macro Intelligence - Environment Variables
# ==============================
# Copy this file to .env.local and fill in the values

# ==============================
# Google Cloud / Vertex AI (Gemini)
# ==============================
# Your Google Cloud project ID
GCP_PROJECT_ID=your-gcp-project-id

# Google Cloud region (e.g., us-central1, europe-west1)
GCP_LOCATION=us-central1

# Path to your Google Cloud service account JSON key file
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account-key.json

# ==============================
# Application Settings
# ==============================
# Application name
NEXT_PUBLIC_APP_NAME=EU Macro Intelligence

# Application URL (used for API calls)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================
# Optional: Mock Data Mode
# ==============================
# When set to "true", the app uses mock data instead of Gemini AI
# This is useful for development and the hackathon demo
NEXT_PUBLIC_MOCK_MODE=true

# ==============================
# Optional: Analytics / Monitoring
# ==============================
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
